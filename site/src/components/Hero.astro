  <div class="hero__canvas-wrap">
    <canvas class="hero__canvas" id="particle-canvas"></canvas>
    <img src="/images/logo.png" alt="Eigenvector" class="hero__logo" id="hero-logo" />
  </div>
  <h1 class="hero__title">Eigenvector</h1>
  <p class="hero__tagline">I find your direction. Then I build along it.</p>
  <div class="btn-group">
    <a href="mailto:busterfranken@gmail.com" class="btn btn--primary">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
