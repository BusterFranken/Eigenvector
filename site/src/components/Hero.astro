  </div>
</section>

<script>
  const canvas = document.getElementById('particle-canvas') as HTMLCanvasElement;
  const logo = document.getElementById('hero-logo') as HTMLImageElement;

  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    const wrap = canvas.parentElement!;

    const size = wrap.offsetWidth;
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    canvas.width = size * dpr;
    canvas.height = size * dpr;
    ctx.scale(dpr, dpr);

    const img = new Image();
    img.crossOrigin = 'anonymous';
    img.src = '/images/logo.png';

    img.onload = () => {
      const sampleSize = size;
      const offscreen = document.createElement('canvas');
      const offCtx = offscreen.getContext('2d')!;
      offscreen.width = sampleSize;
      offscreen.height = sampleSize;
      offCtx.drawImage(img, 0, 0, sampleSize, sampleSize);

      const imageData = offCtx.getImageData(0, 0, sampleSize, sampleSize);
      const pixels = imageData.data;

      // Responsive sample step: fewer particles on mobile
      const step = size < 280 ? 5 : 3;

      interface Particle {
        startX: number;
        startY: number;
        targetX: number;
        targetY: number;
        r: number;
        g: number;
        b: number;
        size: number;
        delay: number;
        settled: boolean;
      }

      const particles: Particle[] = [];

      for (let y = 0; y < sampleSize; y += step) {
        for (let x = 0; x < sampleSize; x += step) {
          const i = (y * sampleSize + x) * 4;
          const r = pixels[i], g = pixels[i + 1], b = pixels[i + 2], a = pixels[i + 3];
          const brightness = (r + g + b) / 3;

          if (brightness < 160 && a > 128) {
            particles.push({
              startX: Math.random() * size,
              startY: Math.random() * size,
              targetX: x,
              targetY: y,
              r, g, b,
              size: 0.8 + Math.random() * 0.8,
              delay: Math.random() * 600,
              settled: false
            });
          }
        }
      }

      const duration = 2200;
      let start: number | null = null;
      let allSettledAt: number | null = null;

      function easeOutCubic(t: number) {
        return 1 - Math.pow(1 - t, 3);
      }

      function animate(timestamp: number) {
        if (!start) start = timestamp;
        const elapsed = timestamp - start;

        ctx.clearRect(0, 0, size, size);

        let allDone = true;

        for (const p of particles) {
          const particleElapsed = Math.max(0, elapsed - p.delay);
          let progress = Math.min(particleElapsed / duration, 1);
          const ease = easeOutCubic(progress);

          const x = p.startX + (p.targetX - p.startX) * ease;
          const y = p.startY + (p.targetY - p.startY) * ease;

          // Fade in particle
          const alpha = Math.min(particleElapsed / 400, 1);

          if (progress < 1) allDone = false;

          ctx.globalAlpha = alpha;
          ctx.fillStyle = `rgb(${p.r}, ${p.g}, ${p.b})`;
          ctx.fillRect(x, y, p.size, p.size);
        }

        ctx.globalAlpha = 1;

        if (allDone) {
          if (!allSettledAt) allSettledAt = timestamp;
          const settledElapsed = timestamp - allSettledAt;

          if (settledElapsed > 400) {
            const fade = Math.min((settledElapsed - 400) / 700, 1);
            canvas.style.opacity = String(1 - fade);
            logo?.classList.add('is-visible');

            if (fade >= 1) {
              canvas.style.display = 'none';
              return;
            }
          }
        }

        requestAnimationFrame(animate);
      }

      requestAnimationFrame(animate);
    };

    // Fallback: if image fails or takes too long, just show the logo
    setTimeout(() => {
      if (!logo?.classList.contains('is-visible')) {
        canvas.style.display = 'none';
        logo?.classList.add('is-visible');
      }
    }, 8000);
  }
</script>
